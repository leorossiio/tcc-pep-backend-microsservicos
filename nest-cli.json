{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/ms-medicos/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/ms-medicos/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/ms-medicos",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "ms-medicos": {
      "type": "application",
      "root": "apps/ms-medicos",
      "entryFile": "main",
      "sourceRoot": "apps/ms-medicos/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ms-medicos/tsconfig.app.json"
      }
    },
    "ms-pacientes": {
      "type": "application",
      "root": "apps/ms-pacientes",
      "entryFile": "main",
      "sourceRoot": "apps/ms-pacientes/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ms-pacientes/tsconfig.app.json"
      }
    }
  }
}